<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HealthCareApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Your Medical Blue Header Color -->
        <item name="colorPrimary">#0C4280</item>
        <item name="colorOnPrimary">#FFFFFF</item> <!-- White text on blue header -->

        <!-- Backgrounds for Light Mode -->
        <item name="android:windowBackground">#F4F6F9</item> <!-- Light grey background -->
        <item name="colorSurface">#FFFFFF</item> <!-- White color for your Cards -->
        <item name="colorOnSurface">#1A1A1A</item> <!-- Dark text color -->

        <!-- Status Bar Color (Matches header) -->
        <item name="android:statusBarColor">#0C4280</item>
    </style>

    <style name="Theme.HealthCareApp" parent="Base.Theme.HealthCareApp" />
</resources>